{
    "compilerOptions": {
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES6",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "declaration": true,
        "outDir": "./dist",
        "types": ["node"],
        "typeRoots": ["node_modules/@types"],
        "lib": ["DOM", "ES2017"]
    },
    "include": ["**/*.ts"]
}
